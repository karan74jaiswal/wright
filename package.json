{
  "name": "wright",
  "version": "1.0.0",
  "scripts": {
    "dev:cli": "cd packages/cli && bun run dev",
    "dev:session": "cd packages/session-service && bun run dev",
    "dev:chat": "cd packages/chat-service && bun run dev",
    "dev:gateway": "cd packages/api-gateway && bun run dev",
    "dev:backend": "bun run dev:session & bun run dev:chat & bun run dev:gateway"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1"
  },
  "intent": {
    "skills": [
      "@tanstack/query",
      "@trpc/server",
      "@trpc/client"
    ]
  }
}
